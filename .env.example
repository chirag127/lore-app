# oriz-family env contract — pulled from the shared envpact 'shared' block.
# This file documents the env vars expected when oriz-book-lore is migrated
# onto the @chirag127/oriz-ui shared scaffold. The legacy web/.env.example
# (BookAtlas / KnowledgeAtlas) is the source of truth for the current build.

# Firebase (shared 'oriz-app' project across every *.oriz.in site)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Cloudflare
PUBLIC_CF_BEACON_TOKEN=
PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET=

# Web3Forms (contact form)
PUBLIC_WEB3FORMS_KEY=

# Newsletter
PUBLIC_BUTTONDOWN_USERNAME=chirag127

# Analytics
PUBLIC_GA4_ID=

# AdSense (uncomment ONLY after publisher approval)
# PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_FUNDING_CHOICES_ID=

# Many static pages (461 books) — give libuv more threads at build time
UV_THREADPOOL_SIZE=64
