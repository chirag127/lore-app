{
  "name": "book-lore",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy",
    "typecheck": "astro check",
    "lint": "biome check src tests astro.config.mjs playwright.config.ts vitest.config.ts",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^6.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.48.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0",
    "wrangler": "^4.102.0"
  }
}
