---
/*
 * Footer — colophon as italic paragraph (Source Serif 4) + utility links in
 * mono small-caps separated by brass middots. Background is `--paper-2`.
 *
 * No newsletter, no email capture, no social icons, no emoji.
 */

const deployTime =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 16).replace('T', ' ')
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'
const year = new Date().getFullYear()
---

<footer class="footer">
  <hr class="hairline" />
  <div class="spine footer-band">
    <p class="colophon">
      Set in Cormorant Garamond and Source Serif 4 on aged cream. Marginalia in Caveat,
      pencil red. Reading ribbon in bottle green. A reading commons under
      <a href="https://oriz.in">oriz.in</a>, since the autumn of 2024.
    </p>
    <nav class="utility-row mono-caps" aria-label="Footer">
      <a href="/books/">shelves</a>
      <span class="bullet" aria-hidden="true">·</span>
      <a href="/about/">about</a>
      <span class="bullet" aria-hidden="true">·</span>
      <a href="/contact/">contact</a>
      <span class="bullet" aria-hidden="true">·</span>
      <a href="/legal/">colophon</a>
      <span class="bullet" aria-hidden="true">·</span>
      <a href="https://github.com/chirag127/oriz-book-lore">source</a>
    </nav>
    <p class="meta mono">
      &copy; {year} chirag singhal · deployed <time datetime={deployTime}>{deployTime}</time> ·
      <code>{gitSha}</code>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 6rem;
    background: var(--paper-2);
  }
  .footer-band {
    padding-block: 2.25rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .colophon {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
    max-width: 64ch;
  }
  .colophon a {
    color: var(--pencil);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--pencil) 50%, transparent);
    text-underline-offset: 3px;
  }
  .utility-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--ink-mute);
    margin: 0.5rem 0 0;
  }
  .utility-row a {
    color: var(--ink-mute);
    text-decoration: none;
  }
  .utility-row a:hover {
    color: var(--pencil);
  }
  .bullet {
    color: var(--brass);
    font-family: var(--font-mono);
  }
  .meta {
    margin: 0.5rem 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'calt' 0;
  }
  .meta code {
    font-family: var(--font-mono);
    color: var(--ink);
    background: transparent;
    padding: 0;
  }
</style>
