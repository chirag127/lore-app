---
/*
 * Header — single 1px brass rule + wordmark + three text links in mono small-caps.
 *
 * Layout (matches design-briefs/oriz-book-lore.md "Header"):
 *   ─── brass rule ────────────────────────────────────────────────────
 *   book·lore                                  shelves · about · /
 *   ─── brass rule ────────────────────────────────────────────────────
 *
 * On book pages, a `breadcrumb` slot can be passed to render a spine line
 * BELOW the rule indented to the article column:
 *   book·lore · cognition · Thinking, Fast and Slow
 *
 * No nav bar, no logo mark, no theme toggle. Theme lives in the footer.
 */
import Wordmark from '~/components/Wordmark.astro'

interface Props {
  /** Optional breadcrumb spine for book pages: e.g. "shelves · cognition · 047" */
  breadcrumb?: string
}

const { breadcrumb } = Astro.props
---

<header class="header">
  <hr class="hairline-brass" />
  <div class="spine header-row">
    <Wordmark href="/" />
    <nav class="header-nav" aria-label="Primary">
      <a href="/books/" class="nav-link mono-caps">shelves</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href="/about/" class="nav-link mono-caps">about</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href="/account/" class="nav-link mono-caps" aria-label="Sign in">/</a>
    </nav>
  </div>
  {breadcrumb && (
    <div class="spine breadcrumb mono-caps">
      <span set:html={breadcrumb} />
    </div>
  )}
</header>

<style>
  .header {
    position: relative;
  }
  .header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    height: 56px;
    padding-block: 14px 0;
  }
  .header-nav {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .nav-link {
    color: var(--ink-mute);
    text-decoration: none;
    transition: color 100ms;
  }
  .nav-link:hover {
    color: var(--pencil);
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--pencil);
    outline-offset: 3px;
  }
  .dot {
    color: var(--brass);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .breadcrumb {
    padding-block: 0.5rem 0.75rem;
    color: var(--ink-mute);
  }
  .breadcrumb :global(a) {
    color: var(--ink-mute);
    text-decoration: none;
  }
  .breadcrumb :global(a:hover) {
    color: var(--pencil);
  }
  @media (max-width: 560px) {
    .header-row {
      flex-wrap: wrap;
      height: auto;
      padding-block: 12px;
      gap: 0.5rem;
    }
  }
</style>
