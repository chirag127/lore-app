---
/*
 * BaseLayout — book-lore aged-cream chrome with Cormorant + Source Serif 4 + Caveat.
 *
 * No oriz-ui style imports. Auth/contact islands are local copies in src/components.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'

import Header from '@chirag127/astro-chrome/Header.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Optional breadcrumb spine for book pages, rendered below the brass rule. */
  breadcrumb?: string
}

const {
  title = `book·lore — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  breadcrumb,
} = Astro.props

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID
import '@chirag127/astro-shell/tokens.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="book·lore" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Caveat:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    {beaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beaconToken}"}`}
      />
    )}

    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>{`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id);
        `}</script>
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header breadcrumb={breadcrumb} />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>
