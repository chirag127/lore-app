---
import BaseLayout from '~/layouts/BaseLayout.astro'
import AccountPanel from '~/components/AccountPanel.tsx'
---

<BaseLayout
  title="Account — book·lore"
  description="Sign in to book·lore. One account works across every oriz site."
  noindex={true}
>
  <section class="spine page">
    <header class="page-head">
      <p class="eyebrow"><a href="/">book·lore</a> / account</p>
      <h1>Account</h1>
      <p class="lede">
        One sign-in works across every <a href="https://oriz.in">oriz</a> site — bookmarks
        and reading state follow you.
      </p>
    </header>

    <div class="prose">
      <AccountPanel client:load siteName="book·lore" />
    </div>
  </section>
</BaseLayout>
