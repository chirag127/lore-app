---
/*
 * /books — alphabetised running list of every volume in the catalogue.
 *
 * NOT a card grid (forbidden by the v2 spec). A long running list with mono
 * small-caps subtitles and the title in Cormorant. The reader can scan
 * vertically; sufficiency dots sit right-aligned per row.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const books = (await getCollection('books')).sort((a, b) => a.data.title.localeCompare(b.data.title))
const totalBooks = books.length

// Sufficiency: how many of the four MDX sections exist on disk for this slug.
const overview = await getCollection('overview')
const content = await getCollection('content')
const analysis = await getCollection('analysis')
const narration = await getCollection('narration')
const slugHas = (col: { id: string }[], slug: string) =>
  col.some((e) => e.id.replace(/\\/g, '/').toLowerCase().includes(`/${slug.toLowerCase()}/`))

// Initial-letter index for the lefthand spine.
const byLetter = new Map<string, typeof books>()
for (const b of books) {
  const c = (b.data.title[0] || '?').toUpperCase()
  if (!byLetter.has(c)) byLetter.set(c, [])
  byLetter.get(c)!.push(b)
}
const letters = Array.from(byLetter.keys()).sort()
---

<BaseLayout
  title="Shelves — book·lore"
  description={`A running list of every volume on book·lore — ${totalBooks} entries, alphabetised.`}
>
  <section class="spine page">
    <header class="page-head">
      <p class="eyebrow"><a href="/">book·lore</a> / shelves</p>
      <h1>Shelves</h1>
      <p class="meta mono-caps">{totalBooks.toLocaleString()} {totalBooks === 1 ? 'volume' : 'volumes'} · alphabetised</p>
    </header>

    <nav class="letter-row mono-caps" aria-label="Jump to letter">
      {letters.map((c) => (
        <a href={`#letter-${c}`}>{c}</a>
      ))}
    </nav>

    {letters.map((c) => (
      <section class="letter-block" id={`letter-${c}`}>
        <h2 class="letter-h"><span>{c}</span></h2>
        <ol class="run-list">
          {byLetter.get(c)!.map((b) => {
            const filled =
              (slugHas(overview, b.data.slug) ? 1 : 0) +
              (slugHas(content, b.data.slug) ? 1 : 0) +
              (slugHas(analysis, b.data.slug) ? 1 : 0) +
              (slugHas(narration, b.data.slug) ? 1 : 0)
            return (
              <li>
                <a href={`/books/${b.data.slug}/`} class="run-link">
                  <span class="run-title">{b.data.title}</span>
                  {b.data.authors[0] && (
                    <span class="run-byline">· {b.data.authors[0]}{b.data.year ? `, ${b.data.year}` : ''}</span>
                  )}
                  <span class="run-suff" aria-label={`${filled} of 4 sections`}>
                    {Array.from({ length: 4 }).map((_, i) => (
                      <span class={i < filled ? 'dot fill' : 'dot'}>●</span>
                    ))}
                  </span>
                </a>
              </li>
            )
          })}
        </ol>
      </section>
    ))}

    {totalBooks === 0 && <p class="empty">No volumes shelved yet.</p>}
  </section>
</BaseLayout>

<style>
  .page { padding-block: 2rem 5rem; }
  .letter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin: 2rem 0 1rem;
    padding-block: 0.5rem;
    border-block: 1px solid var(--rule);
  }
  .letter-row a {
    color: var(--ink-mute);
    text-decoration: none;
  }
  .letter-row a:hover {
    color: var(--pencil);
  }
  .letter-block {
    margin-block: 2rem 1rem;
  }
  .letter-h {
    position: sticky;
    top: 0;
    background: var(--paper);
    margin: 0 0 0.5rem;
    padding-block: 0.5rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--brass);
  }
  .letter-h span {
    background: var(--paper);
    padding-right: 0.5rem;
  }
  .run-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .run-list li {
    border-top: 1px solid var(--rule);
  }
  .run-list li:last-child {
    border-bottom: 1px solid var(--rule);
  }
  .run-link {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    padding-block: 0.875rem;
    text-decoration: none;
    color: var(--ink);
    flex-wrap: wrap;
  }
  .run-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--ink);
  }
  .run-link:hover .run-title {
    color: var(--pencil);
  }
  .run-byline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-mute);
  }
  .run-suff {
    margin-left: auto;
    display: inline-flex;
    gap: 0.125em;
  }
  .dot {
    color: var(--rule);
    font-size: 0.6875rem;
  }
  .dot.fill {
    color: var(--pencil);
  }
  .empty {
    color: var(--ink-mute);
    font-style: italic;
  }
</style>
