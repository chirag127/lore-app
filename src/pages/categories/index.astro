---
/*
 * /categories — the shelves index, an outline of disciplines and
 * sub-disciplines. Rendered as nested running lists, NOT cards.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const books = await getCollection('books')

interface SubNode { name: string; slug: string; count: number }
interface CatNode { name: string; slug: string; count: number; subs: Map<string, SubNode> }

function labelFromSlug(slug: string) {
  const cleaned = slug.replace(/^\d+-/, '')
  return cleaned.split('-').join(' ')
}

const cats = new Map<string, CatNode>()
for (const b of books) {
  const cat = b.data.category ?? 'uncategorized'
  const sub = b.data.subcategory ?? 'general'
  if (!cats.has(cat)) cats.set(cat, { name: labelFromSlug(cat), slug: cat, count: 0, subs: new Map() })
  const c = cats.get(cat)!
  c.count++
  if (!c.subs.has(sub)) c.subs.set(sub, { name: labelFromSlug(sub), slug: sub, count: 0 })
  c.subs.get(sub)!.count++
}

const sorted = Array.from(cats.values()).sort((a, b) => b.count - a.count)
const totalBooks = books.length
const totalCategories = sorted.length
const totalSubcategories = sorted.reduce((s, c) => s + c.subs.size, 0)
---

<BaseLayout
  title="Shelves index — book·lore"
  description={`Two-level taxonomy: ${totalCategories} disciplines, ${totalSubcategories} sub-disciplines, ${totalBooks} volumes.`}
>
  <section class="spine page">
    <header class="page-head">
      <p class="eyebrow"><a href="/">book·lore</a> / shelves index</p>
      <h1>Shelves index</h1>
      <p class="meta mono-caps">
        {totalCategories} disciplines · {totalSubcategories} sub-disciplines · {totalBooks.toLocaleString()} volumes
      </p>
    </header>

    <ol class="cat-list">
      {sorted.map((cat) => (
        <li class="cat" id={cat.slug}>
          <header class="cat-rule">
            <span class="cat-name label-display">{cat.name}</span>
            <span class="cat-count mono-caps">{cat.count} {cat.count === 1 ? 'volume' : 'volumes'}</span>
          </header>
          <ul class="sub-list">
            {Array.from(cat.subs.values()).sort((a, b) => b.count - a.count).map((sub) => (
              <li class="sub">
                <span class="sub-name">{sub.name}</span>
                <span class="dot-fill" aria-hidden="true">·</span>
                <span class="sub-count mono-caps">{sub.count}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .page { padding-block: 2rem 5rem; }
  .cat-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }
  .cat-rule {
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.875rem;
    margin-bottom: 0.75rem;
  }
  .cat-rule::before {
    content: '';
    position: absolute;
    left: 0; right: 0; top: 50%;
    height: 1px;
    background: color-mix(in oklab, var(--brass) 70%, transparent);
    transform: translateY(-50%);
  }
  .cat-name,
  .cat-count {
    position: relative;
    background: var(--paper);
    padding-inline: 0.5rem;
  }
  .cat-name {
    font-size: 1.25rem;
    padding-left: 0;
    color: var(--ink);
  }
  .cat-count {
    color: var(--brass);
    padding-right: 0;
  }
  .sub-list {
    list-style: none;
    padding: 0 0 0 1ch;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.375rem;
  }
  @media (min-width: 720px) {
    .sub-list { grid-template-columns: 1fr 1fr; column-gap: 1.5rem; }
  }
  .sub {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--ink);
    border-bottom: 1px dotted var(--rule);
    padding-block: 0.25rem;
  }
  .sub-name { flex: 1; }
  .sub-count { color: var(--ink-mute); }
  .dot-fill { color: var(--brass); }
</style>
