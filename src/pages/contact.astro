---
/*
 * /contact — Web3Forms-backed static form using `[data-oriz-contact-*]` hooks.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — book·lore"
  description="Get in touch — typo, broken link, request a book, or feedback."
>
  <section class="spine page">
    <header class="page-head">
      <p class="eyebrow"><a href="/">book·lore</a> / contact</p>
      <h1>Contact</h1>
      <p class="lede">
        Email is fastest:
        <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
      </p>
    </header>

    <div class="prose">
      <p>
        For anything site-related — typo on a page, broken link, suggestion, or to request a
        book — use the form below. It posts to <a href="https://web3forms.com">Web3Forms</a>
        which forwards to my inbox. No data is stored on this site.
      </p>

      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        data-oriz-contact
        data-oriz-contact-status="idle"
      >
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="from_name" value="book-lore.oriz.in contact form" />
        <input
          type="text"
          name="botcheck"
          data-oriz-contact-honeypot
          tabindex="-1"
          autocomplete="off"
        />
        <label data-oriz-contact-field="name">
          <span>Your name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label data-oriz-contact-field="email">
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label data-oriz-contact-field="subject">
          <span>Subject</span>
          <input type="text" name="subject" required />
        </label>
        <label data-oriz-contact-field="message">
          <span>Message</span>
          <textarea name="message" rows="6" required></textarea>
        </label>
        <button type="submit" data-oriz-contact-submit>Send</button>
      </form>

      <p class="meta-note">
        For privacy questions or DMCA notices, see the
        <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .meta-note {
    font-size: 0.875rem;
    color: var(--ink-mute);
    margin-top: 2rem;
  }
</style>
