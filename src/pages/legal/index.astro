---
import BaseLayout from '~/layouts/BaseLayout.astro'

const sections = [
  { slug: 'privacy', label: 'Privacy policy', desc: 'What we collect, what we don\'t, your rights.' },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using book-lore.oriz.in.' },
  { slug: 'disclaimer', label: 'Disclaimer', desc: 'Summaries are commentary — not the original work.' },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout title="Colophon & legal — book·lore" description="Privacy, terms, and grievance contact for book·lore.">
  <section class="spine page">
    <header class="page-head">
      <p class="eyebrow"><a href="/">book·lore</a> / colophon</p>
      <h1>Colophon &amp; legal</h1>
      <p class="lede">The fine print, set in the same type as the marginalia.</p>
    </header>

    <ul class="legal-list">
      {sections.map((s) => (
        <li>
          <a href={`/legal/${s.slug}/`} class="row">
            <span class="row-label label-display">{s.label}</span>
            <span class="row-desc">{s.desc}</span>
            <span class="row-arrow mono-caps" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page { padding-block: 2rem 5rem; }
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }
  .legal-list li {
    border-top: 1px solid var(--rule);
  }
  .legal-list li:last-child {
    border-bottom: 1px solid var(--rule);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 2fr auto;
    gap: 1rem;
    align-items: baseline;
    padding-block: 1rem;
    text-decoration: none;
    color: inherit;
  }
  .row-label {
    font-size: 1rem;
  }
  .row-desc {
    color: var(--ink-mute);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 0.9375rem;
  }
  .row-arrow {
    color: var(--brass);
  }
  .row:hover .row-label {
    color: var(--pencil);
  }
  .row:hover .row-arrow {
    color: var(--pencil);
  }
  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr auto; }
    .row-desc { grid-column: 1 / -1; margin-top: 0.25rem; }
  }
</style>
