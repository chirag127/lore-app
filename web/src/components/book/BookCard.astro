---
import type { CollectionEntry } from 'astro:content';
import CoverArt from './CoverArt.astro';

interface Props {
  book: CollectionEntry<'books'>;
  featured?: boolean;
}

const { book, featured = false } = Astro.props;
const d = book.data;
const accent = d.cover?.color ?? '#c44536';
---
<article class="grain-card grain-overlay p-5 sm:p-6 group flex flex-col h-full">
  <a href={`/books/${d.slug}`} class="block -m-5 sm:-m-6 p-5 sm:p-6 focus-ring">
    <div class="flex gap-4 items-start">
      <div class="w-20 sm:w-24 flex-shrink-0">
        <CoverArt
          title={d.title}
          author={d.authors[0]}
          cover={d.cover}
          accent={accent}
        />
      </div>
      <div class="min-w-0 flex-1">
        <p class="font-mono text-[0.625rem] uppercase tracking-[0.22em] text-ink-mute truncate">
          {d.authors[0]}{d.year ? ` · ${d.year}` : ''}
        </p>
        <h3 class="mt-1 font-display text-lg sm:text-xl font-light leading-snug text-balance group-hover:text-terracotta-500 transition-colors">
          {d.title}
        </h3>
      </div>
    </div>
    {featured && (
      <p class="mt-3 text-sm text-ink-soft line-clamp-3 italic">
        {d.excerpt}
      </p>
    )}
  </a>
  <div class="mt-auto pt-4 flex flex-wrap items-center gap-2">
    {d.tags.slice(0, 3).map((t) => (
      <a
        href={`/books?tag=${encodeURIComponent(t)}`}
        class="inline-flex items-center h-5 px-2 font-mono text-[0.625rem] uppercase tracking-[0.18em] border border-rule text-ink-soft hover:border-terracotta-400 hover:text-terracotta-500 transition-colors"
      >{t}</a>
    ))}
    {d.readingTimeMinutes && (
      <span class="ml-auto font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">
        {d.readingTimeMinutes}m read
      </span>
    )}
  </div>
</article>
