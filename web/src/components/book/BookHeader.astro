---
import type { CollectionEntry } from 'astro:content';
import { BookmarkButton, StatusWidget, PublicReviewSummary } from './BookActions';
import CoverArt from './CoverArt.astro';

interface Props {
  book: CollectionEntry<'books'>;
  active: 'overview' | 'content' | 'analysis' | 'narration' | 'notes' | 'reviews';
  totalChapters?: number;
}

const { book, active } = Astro.props;
const data = book.data;
const tabs = [
  { id: 'overview',  href: `/books/${data.slug}`,                   label: 'Overview' },
  { id: 'content',   href: `/books/${data.slug}/content`,           label: 'Content' },
  { id: 'analysis',  href: `/books/${data.slug}/analysis`,          label: 'Analysis' },
  { id: 'narration', href: `/books/${data.slug}/narration`,         label: 'Narration' },
  { id: 'notes',     href: `/books/${data.slug}/notes`,             label: 'Notes' },
  { id: 'reviews',   href: `/books/${data.slug}/reviews`,           label: 'Reviews' },
];
---
<article class="grain-card grain-overlay overflow-hidden">
  <div class="grid lg:grid-cols-[280px_1fr] gap-0">
    <div class="bg-paper-deep/50 p-5 sm:p-6 md:p-8 flex flex-col items-center sm:items-center lg:items-start gap-4 border-b lg:border-b-0 lg:border-r border-rule">
      <div class="w-36 sm:w-52">
        <CoverArt
          title={data.title}
          author={data.authors[0]}
          cover={data.cover}
          accent={data.cover?.color}
          class="shadow-[var(--shadow-lift)]"
        />
      </div>
      <div class="w-full">
        <p class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-ink-mute">
          {data.publisher ?? 'Unknown publisher'}
          {data.year ? ` · ${data.year}` : ''}
        </p>
        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-light leading-tight mt-1 text-balance">
          {data.title}
        </h1>
        {data.subtitle && (
          <p class="text-ink-soft mt-1 italic text-pretty">{data.subtitle}</p>
        )}
        <p class="text-sm text-ink-soft mt-3">
          {data.authors.join(', ')}
        </p>
        <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
          {data.readingTimeMinutes && (
            <div>
              <dt class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">Reading</dt>
              <dd>{data.readingTimeMinutes} min</dd>
            </div>
          )}
          {data.listeningTimeMinutes && (
            <div>
              <dt class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">Listening</dt>
              <dd>{data.listeningTimeMinutes} min</dd>
            </div>
          )}
          <div>
            <dt class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">Difficulty</dt>
            <dd class="capitalize">{data.difficulty}</dd>
          </div>
          {data.pages && (
            <div>
              <dt class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">Pages</dt>
              <dd>{data.pages}</dd>
            </div>
          )}
        </dl>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <BookmarkButton slug={data.slug} client:load />
          <StatusWidget slug={data.slug} title={data.title} client:load />
        </div>
        <div class="mt-3">
          <PublicReviewSummary slug={data.slug} client:load />
        </div>
      </div>
    </div>

    <div class="p-5 sm:p-6 md:p-8 min-w-0">
      <nav class="border-b border-rule overflow-x-auto no-scrollbar -mx-5 sm:-mx-6 md:-mx-8 px-5 sm:px-6 md:px-8" aria-label="Book sections">
        <ul class="flex gap-1 min-w-max">
          {tabs.map((t) => (
            <li>
              <a
                href={t.href}
                class:list={[
                  'inline-block px-3 py-3 font-mono text-[0.6875rem] uppercase tracking-[0.2em] transition-colors whitespace-nowrap',
                  active === t.id ? 'text-terracotta-500 border-b border-terracotta-400' : 'text-ink-mute hover:text-ink',
                ]}
              >{t.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      <div class="pt-6">
        <slot />
      </div>
    </div>
  </div>
</article>
