---
const links = [
  { href: '/books', label: 'Atlas' },
  { href: '/categories', label: 'Categories' },
  { href: '/request', label: 'Request' },
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/library', label: 'Library' },
  { href: '/collections', label: 'Collections' },
];
import { SearchBox } from '../search/SearchBox.tsx';
import { AuthMenu } from '../auth/AuthMenu.tsx';
import { ThemeToggle } from '../ui/ThemeToggle.tsx';
import { MobileNav } from './MobileNav.tsx';
import { getCollection } from 'astro:content';

const current = Astro.url.pathname;
const books = await getCollection('books');
const count = books.length;
---
<header class="sticky top-0 z-30 backdrop-blur-md bg-paper/85 border-b border-rule">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center gap-2 sm:gap-4">
    <a href="/" class="group flex items-center gap-2 font-display text-lg sm:text-xl font-light tracking-tight min-w-0" aria-label="KnowledgeAtlas home">
      <svg viewBox="0 0 32 32" width="26" height="26" aria-hidden="true" class="text-terracotta-500 group-hover:text-terracotta-600 transition-colors flex-shrink-0">
        <circle cx="16" cy="16" r="15" fill="none" stroke="currentColor" stroke-width="1.5" />
        <path d="M16 2v28M2 16h28M6 6l20 20M26 6 6 26" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
        <path d="M8 11h16v10H8z" fill="currentColor" opacity="0.15" />
        <text x="16" y="19.5" text-anchor="middle" font-family="serif" font-size="10" fill="currentColor">K</text>
      </svg>
      <span class="truncate">Knowledge<span class="italic font-variation-wonk">Atlas</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-1 ml-4" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'px-3 h-9 inline-flex items-center font-mono text-[0.6875rem] uppercase tracking-[0.2em] transition-colors',
            current === l.href || (l.href !== '/' && current.startsWith(l.href))
              ? 'text-terracotta-500'
              : 'text-ink-soft hover:text-ink',
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex-1 max-w-md hidden sm:block">
      <SearchBox client:load />
    </div>

    <div class="ml-auto flex items-center gap-2">
      <span class="hidden md:inline font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-ink-mute">
        {count.toLocaleString()} books
      </span>
      <div class="hidden sm:flex items-center gap-2">
        <ThemeToggle client:load />
        <AuthMenu client:load />
      </div>
      <MobileNav
        client:load
        links={links}
        currentPath={current}
        bookCount={count}
      />
    </div>
  </div>
</header>
