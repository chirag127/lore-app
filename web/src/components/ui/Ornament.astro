---
const { eyebrow = 'Ornament' } = Astro.props as { eyebrow?: string; children?: unknown };
---
<div class="ornament">
  <span class="ornament-mark"></span>
  <span class="font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-ink-mute">{eyebrow}</span>
  <span class="ornament-mark"></span>
</div>
