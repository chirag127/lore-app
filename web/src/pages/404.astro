---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Ornament } from '../components/ui/Primitives.tsx';
---
<BaseLayout title="Not found" description="This page doesn't exist in the atlas.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-32 text-center">
    <Ornament client:load>404</Ornament>
    <h1 class="font-display text-display-xl font-light mt-8 text-balance">
      Off the map.
    </h1>
    <p class="mt-4 text-ink-soft text-pretty">
      The page you're looking for doesn't exist in the atlas. Try the
      <a href="/books" class="text-terracotta-500">atlas</a>, or
      <a href="/search" class="text-terracotta-500">search</a>.
    </p>
  </section>
</BaseLayout>
