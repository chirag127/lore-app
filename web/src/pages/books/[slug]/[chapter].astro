---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookHeader from '../../../components/book/BookHeader.astro';
import { Ornament } from '../../../components/ui/Primitives.tsx';
import { SpeechPlayer } from '../../../components/narration/SpeechPlayer.tsx';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const chapters = ['content', 'analysis', 'narration'] as const;
  return books.flatMap((b) =>
    chapters.map((chapter) => ({
      params: { slug: b.data.slug, chapter },
    })),
  );
}

type Chapter = 'content' | 'analysis' | 'narration';

const { slug, chapter } = Astro.params as { slug: string; chapter: Chapter };

const book = (await getCollection('books')).find((b) => b.data.slug === slug);
if (!book) return Astro.redirect('/404');

const all = await getCollection(chapter);
type ChapterEntry = CollectionEntry<Chapter>;
const chapterFile = chapter === 'narration' ? '03-narration' : chapter === 'analysis' ? '02-analysis' : '01-content';
const entry: ChapterEntry | undefined = all.find(
  (e) => e.id === `${book.id}/${chapterFile}` || e.id === `${book.id}/${chapterFile}.mdx`,
);
const rendered = entry ? await render(entry) : null;
const Content = rendered ? rendered.Content : null;
const body = entry?.body ?? '';
const totalWords = body ? body.split(/\s+/).length : 0;
const listeningMinutes = Math.max(1, Math.round(totalWords / 160));
const titleForTab = entry?.data?.title ?? `${book.data.title} — ${chapter}`;
---
<BaseLayout
  title={`${book.data.title} — ${chapter.charAt(0).toUpperCase()}${chapter.slice(1)}`}
  description={`${book.data.title} — the ${chapter} chapter of the KnowledgeAtlas entry.`}
  image={book.data.cover?.url}
  type="book"
  bookData={{
    slug: book.data.slug,
    title: book.data.title,
    authors: book.data.authors,
    cover: book.data.cover?.url,
    year: book.data.year,
    excerpt: book.data.excerpt,
  }}
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10 md:py-16">
    <BookHeader book={book} active={chapter}>
      <Ornament client:load>{chapter}</Ornament>
      <h2 class="font-display text-display-md font-light mt-4 mb-2 text-balance">
        {titleForTab}
      </h2>
      <p class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-ink-mute mb-8 sm:mb-10">
        ~{totalWords.toLocaleString()} words · {listeningMinutes} min listen
      </p>
      {chapter === 'narration' ? (
        <div class="space-y-6 sm:space-y-8">
          <SpeechPlayer client:load source={body} estimatedMinutes={listeningMinutes} estimatedWords={totalWords} />
          <details class="text-sm text-ink-soft">
            <summary class="cursor-pointer font-mono text-[0.6875rem] uppercase tracking-[0.18em]">Read the script</summary>
            {Content && <div class="prose-bookatlas mt-6"><Content /></div>}
          </details>
        </div>
      ) : (
        Content ? <div class="prose-bookatlas"><Content /></div> : (
          <p class="text-ink-soft italic">This chapter hasn't been generated yet.</p>
        )
      )}
    </BookHeader>
  </section>
</BaseLayout>
