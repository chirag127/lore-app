---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const paths: { params: { slug: string; sub: string } }[] = [];
  const books = await getCollection('books');
  for (const b of books) {
    if (b.data.category && b.data.subcategory) {
      paths.push({ params: { slug: b.data.category, sub: b.data.subcategory } });
    }
  }
  return paths;
}

const { slug, sub } = Astro.params;
const books = await getCollection('books');
const subBooks = books.filter(b => b.data.category === slug && b.data.subcategory === sub);

// Get subcategory overview
const overviewAll = await getCollection('overview');
const subSlug = `${slug}/${sub}`;
const overviewEntry = overviewAll.find(e => e.id.startsWith(subSlug.replace('/', '\\')));
let Content = null;
if (overviewEntry) {
  const rendered = await render(overviewEntry);
  Content = rendered.Content;
}

// Derive display names
const catName = slug.split('-').slice(1).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
const subName = sub.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---

<BaseLayout title={`${subName} — ${catName} — KnowledgeAtlas`} description={`Browse ${subBooks.length} books in ${subName}.`}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-terracotta-500">
      <a href="/categories" class="hover:text-terracotta-600">Categories</a>
      <span class="mx-2">·</span>
      <a href={`/category/${slug}`} class="hover:text-terracotta-600">{catName}</a>
    </p>
    <h1 class="font-display text-display-lg font-light mt-4 mb-2 text-balance">
      {subName}
    </h1>
    <p class="text-ink-soft text-pretty max-w-2xl">
      {subBooks.length} {subBooks.length === 1 ? 'book' : 'books'} in this subcategory.
    </p>

    {Content && (
      <div class="prose-bookatlas mt-8 p-5 sm:p-6 border border-rule grain-card grain-overlay">
        <Content />
      </div>
    )}

    <div class="mt-12 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-3 sm:gap-x-4 gap-y-6">
      {subBooks.sort((a, b) => (a.data.addedAt ?? 0) > (b.data.addedAt ?? 0) ? -1 : 1).map((b) => (
        <a href={`/books/${b.data.slug}`} class="group block">
          {b.data.cover?.url ? (
            <img src={b.data.cover.url} alt={b.data.title} class="w-full aspect-[2/3] object-cover shadow-sm group-hover:shadow-md transition-shadow" loading="lazy" />
          ) : (
            <div class="w-full aspect-[2/3] bg-parchment-100 border border-rule flex items-center justify-center p-3">
              <span class="font-display text-sm text-center text-ink-soft leading-tight">{b.data.title}</span>
            </div>
          )}
          <h3 class="mt-2 font-display text-sm font-light leading-tight text-pretty group-hover:text-terracotta-500 transition-colors">
            {b.data.title}
          </h3>
          <p class="text-xs text-ink-soft truncate">{b.data.authors.join(', ')}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
