---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ContinueReading } from '../components/dashboard/ContinueReading.tsx';
import { BookmarksList } from '../components/dashboard/BookmarksList.tsx';
import { PublicCollections } from '../components/collections/PublicCollections.tsx';
import { Ornament, Stat } from '../components/ui/Primitives.tsx';

const books = await getCollection('books');
const allBooks = books.map((b) => ({ slug: b.data.slug, data: { title: b.data.title } }));
const total = books.length;
---
<BaseLayout title="Dashboard" description="Your KnowledgeAtlas home — keep reading, keep learning.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
    <Ornament client:load>Dashboard</Ornament>
    <h1 class="font-display text-display-lg font-light mt-6 mb-8 sm:mb-12 text-balance">
      Welcome back to the atlas
    </h1>

    <div class="grid lg:grid-cols-[1fr_300px] gap-8 lg:gap-10">
      <div class="space-y-10 sm:space-y-12 min-w-0">
        <section>
          <h2 class="font-display text-xl sm:text-2xl font-light mb-4">Continue reading</h2>
          <ContinueReading client:load />
        </section>
        <section>
          <h2 class="font-display text-xl sm:text-2xl font-light mb-4">Your library</h2>
          <BookmarksList client:load allBooks={allBooks} />
        </section>
        <PublicCollections />
      </div>
      <aside class="space-y-6 sm:space-y-8">
        <div class="grain-card grain-overlay p-5 sm:p-6">
          <Ornament client:load>Atlas</Ornament>
          <h3 class="font-display text-xl sm:text-2xl font-light mt-4 mb-5 sm:mb-6">By the numbers</h3>
          <div class="grid grid-cols-3 gap-2 sm:gap-4">
            <Stat label="Books" value={total.toLocaleString()} />
            <Stat label="Tags" value={new Set(books.flatMap((b) => b.data.tags)).size.toLocaleString()} />
            <Stat label="Free" value="$0" />
          </div>
        </div>
        <div class="grain-card grain-overlay p-5 sm:p-6">
          <Ornament client:load>Quick links</Ornament>
          <ul class="mt-5 sm:mt-6 space-y-3 text-sm">
            <li><a href="/library" class="hover:text-terracotta-500">→ Library</a></li>
            <li><a href="/collections" class="hover:text-terracotta-500">→ Collections</a></li>
            <li><a href="/request" class="hover:text-terracotta-500">→ Request a book</a></li>
            <li><a href="/search" class="hover:text-terracotta-500">→ Search</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
