---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Ornament } from '../components/ui/Primitives.tsx';
import AllNotes from '../components/notes/AllNotes.tsx';

const books = await getCollection('books');
const slugToTitle = new Map(books.map((b) => [b.data.slug, b.data.title]));
---
<BaseLayout title="Notes" description="All your reading notes, one place.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
    <Ornament client:load>All notes</Ornament>
    <h1 class="font-display text-display-lg font-light mt-6 mb-8 sm:mb-12 text-balance">
      Every note you've ever written
    </h1>
    <AllNotes client:load slugToTitle={Object.fromEntries(slugToTitle)} />
  </section>
</BaseLayout>
