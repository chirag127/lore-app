---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Ornament } from '../components/ui/Primitives.tsx';
import AllReviews from '../components/reviews/AllReviews.tsx';

const books = await getCollection('books');
const slugToTitle = new Map(books.map((b) => [b.data.slug, b.data.title]));
---
<BaseLayout title="Reviews" description="Your reviews of every book.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
    <Ornament client:load>All reviews</Ornament>
    <h1 class="font-display text-display-lg font-light mt-6 mb-8 sm:mb-12 text-balance">
      Your shelf of verdicts
    </h1>
    <AllReviews client:load slugToTitle={Object.fromEntries(slugToTitle)} />
  </section>
</BaseLayout>
